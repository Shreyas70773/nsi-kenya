# =============================================================================
# North Star Impex Kenya — environment variables
# Copy to .env.local and fill in real values for local dev.
# =============================================================================

# --- Site ---------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://northstarimpex.co.ke
SITE_NAME="North Star Impex Kenya"
CONTACT_EMAIL=hello@northstarimpex.co.ke
CONTACT_PHONE=+254-XXX-XXXXXX

# --- Convex -------------------------------------------------------------------
# Set by `npx convex dev` on first run. Convex docs:
#   https://docs.convex.dev/quickstart/nextjs
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# --- NextAuth (admin only) ---------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL_ALLOWLIST=

# --- Resend (transactional email) --------------------------------------------
RESEND_API_KEY=
QUOTE_NOTIFICATION_EMAIL=
REFERENCE_CALL_NOTIFICATION_EMAIL=

# --- Google Sheets lead mirror -----------------------------------------------
# Apps Script web-app /exec URL. See APPS-SCRIPT.md for the Code.gs that
# binds it to a sheet. Missing var = mirror is a no-op (Convex still saves).
GSHEETS_WEBHOOK_URL=

# --- Analytics ---------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=northstarimpex.co.ke

# --- Monitoring --------------------------------------------------------------
SENTRY_DSN=

# --- Research (optional, dev-only) -------------------------------------------
FIRECRAWL_API_KEY=
